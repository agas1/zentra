APP_NAME=Orbita
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GERE_UMA_NOVA_KEY
APP_URL=https://orbita-api.onrender.com

# Database - Render PostgreSQL
DB_CONNECTION=pgsql
DB_URL=
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Redis - Render Redis
REDIS_CLIENT=predis
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=null

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# Broadcasting (desabilitado por enquanto)
BROADCAST_CONNECTION=log

# CORS - URL do frontend na Vercel
FRONTEND_URL=https://orbita.vercel.app

# JWT
JWT_SECRET=GERE_UM_NOVO_JWT_SECRET
JWT_ALGO=HS256
JWT_TTL=15
JWT_REFRESH_TTL=10080

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://orbita-api.onrender.com/api/v1/auth/google/callback

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
